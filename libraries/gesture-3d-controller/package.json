{
  "name": "gesture-3d-controller",
  "version": "1.0.0",
  "description": "Reusable library for hand gesture detection and 3D object control using MediaPipe and Three.js",
  "type": "module",
  "main": "dist/index.js",
  "module": "src/index.js",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "require": "./dist/index.js"
    }
  },
  "keywords": [
    "gesture",
    "hand-tracking",
    "mediapipe",
    "three.js",
    "3d",
    "interaction",
    "webcam"
  ],
  "author": "Tarek Bouhlel",
  "license": "MIT",
  "peerDependencies": {
    "three": ">=0.160.0"
  },
  "devDependencies": {
    "three": "^0.162.0"
  }
}
